# Chrome CDP connection
# CHATGPT_SYNC_CDP_HTTP=http://127.0.0.1:9222

# Workspace and output
# CHATGPT_SYNC_WORKSPACE_DIR=./output
# CHATGPT_SYNC_INBOX_DIR=
# CHATGPT_SYNC_ASSET_STRATEGY=fixed-folder
# CHATGPT_SYNC_ASSET_FIXED_DIR=assets
# CHATGPT_SYNC_ASSET_SUBDIR=assets

# Normal sync
# CHATGPT_SYNC_MODE=incremental
# CHATGPT_SYNC_LIST_LIMIT=28
# CHATGPT_SYNC_COUNT=50
# CHATGPT_SYNC_DAYS=14
# CHATGPT_SYNC_OVERLAP_MINUTES=60

# First-run bootstrap
CHATGPT_SYNC_BOOTSTRAP_MODE=count
CHATGPT_SYNC_BOOTSTRAP_COUNT=5
# CHATGPT_SYNC_BOOTSTRAP_DAYS=14

# Single conversation export
# CHATGPT_SYNC_CONVERSATION_ID=

# Debug output
# CHATGPT_SYNC_RENDER_UNKNOWN_PARTS_AS_JSON=false
# CHATGPT_SYNC_DUMP_RAW_CONVERSATION_JSON=false
